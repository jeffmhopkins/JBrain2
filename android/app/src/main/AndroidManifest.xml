<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Background survival: restart tracking after a reboot, run a doze-piercing
         watchdog alarm, and ask to be exempt from battery optimization so the OS
         doesn't suspend the service (the JBrain360 "failing in the background" fix). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.JBrain360">
        <activity
            android:name=".DashboardActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".PairingActivity"
            android:exported="false" />
        <!-- The owner app: same APK, its own launcher icon. It hosts the owner SPA (server
             root) in a WebView so the system back gesture is a native callback we control
             (background-not-exit + the page's window.__jbrainBack bridge), which the PWA
             can't guarantee on Android. enableOnBackInvokedCallback opts this activity into
             the predictive-back callback on Android 13+. -->
        <activity
            android:name=".OwnerActivity"
            android:label="@string/owner_app_name"
            android:enableOnBackInvokedCallback="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".OwnerSetupActivity"
            android:exported="false" />
        <service
            android:name=".LocationService"
            android:exported="false"
            android:foregroundServiceType="location" />
        <!-- Revival point for the watchdog alarm and the boot broadcast. Exported so
             the system can deliver BOOT_COMPLETED; the alarm targets it by explicit
             component, needing no extra intent-filter. -->
        <receiver
            android:name=".WatchdogReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
