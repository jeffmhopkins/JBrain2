# OPT-IN whisper.cpp transcription server for the on-box `whisper` gateway.
#
# The official llama-swap unified Vulkan image (ghcr.io/mostlygeek/llama-swap:vulkan)
# bundles llama-server + sd-server + llama-swap, but NOT whisper.cpp — so the
# generated llama-swap config's `whisper-server` command can't start
# ("executable file not found in $PATH"). We build whisper.cpp's server from
# source and drop it onto PATH in that image, which already ships ffmpeg (so
# whisper's --convert handles non-WAV audio like m4a/mp3/ogg).
#
# Built in the SAME base image so the binary's glibc/libstdc++ match the runtime.
# A CPU build (no Vulkan dev toolchain / glslc needed) keeps the build reliable and
# the binary self-contained — ggml falls back to CPU anyway, and large-v3-turbo is
# quick on the Strix Halo's CPU. (A Vulkan/iGPU build is a future perf follow-up.)
#
# This image is built only when the operator enables transcription; it is never
# part of the default stack.

ARG WHISPER_BASE=ghcr.io/mostlygeek/llama-swap:vulkan

FROM ${WHISPER_BASE} AS build
RUN apt-get update \
 && apt-get install -y --no-install-recommends git build-essential cmake ca-certificates \
 && rm -rf /var/lib/apt/lists/*
# Pin a known-good whisper.cpp release (carries --inference-path + --convert, the
# OpenAI-audio-endpoint flags the gateway config relies on).
ARG WHISPER_CPP_VERSION=v1.7.4
RUN git clone --depth 1 --branch "${WHISPER_CPP_VERSION}" \
      https://github.com/ggml-org/whisper.cpp /src
WORKDIR /src
# Static link (BUILD_SHARED_LIBS=OFF) so whisper-server carries its own ggml and
# can't collide with the base image's bundled libggml*.so (a different version).
RUN cmake -B build -DCMAKE_BUILD_TYPE=Release -DBUILD_SHARED_LIBS=OFF \
      -DWHISPER_BUILD_TESTS=OFF -DWHISPER_BUILD_EXAMPLES=ON \
 && cmake --build build --target whisper-server -j"$(nproc)"

FROM ${WHISPER_BASE}
# Onto PATH so the generated llama-swap config can invoke it by bare name.
COPY --from=build /src/build/bin/whisper-server /usr/local/bin/whisper-server
