# flush_interval -1 disables response buffering so SSE log streams arrive
# line-by-line instead of in bursts.
#
# JBRAIN_SITE_ADDR is the bare domain in direct mode (Caddy fetches a Let's
# Encrypt cert — needs inbound 80/443), or "http://<domain>" in Cloudflare
# Tunnel mode (Caddy serves plain HTTP on :80 and TLS terminates at
# Cloudflare's edge; the tunnel reaches us here at http://proxy:80). It
# defaults to JBRAIN_DOMAIN in compose, so pre-tunnel installs are unchanged.

# Shared app handlers, imported by every site below (the public site and the
# optional LAN site) so they serve the identical app from one definition.
(app) {
	encode zstd gzip

	# The host-mode jcode preview is served ONLY on its own <slug>-preview.<host>
	# subdomain (the preview site below). 404 the internal prefix on every app surface
	# (public + LAN) so a sandbox-run dev app can never be served on the owner origin.
	handle /__jcode_preview* {
		respond 404
	}

	handle /api/* {
		reverse_proxy api:8000 {
			flush_interval -1
		}
	}

	handle {
		root * /srv/www

		# The member dashboard (JBrain360) is a second SPA entry served at /dash
		# (loaded inside the forked app's WebView). It has no client-side router,
		# so /dash and /dash/ both resolve to its built entry; its hash-named
		# assets are shared with the owner app under /assets/.
		@dash path /dash /dash/
		rewrite @dash /dash.html

		# The owner debug console is a third standalone entry; the clean /debug-console
		# path resolves to its built page (token-authed, opened from the PWA).
		@console path /debug-console /debug-console/
		rewrite @console /debug-console.html

		try_files {path} /index.html

		# The PWA's update entrypoints must always revalidate, while Vite's
		# hash-named assets are immutable — this pair is what makes every
		# launch pick up a new deploy.
		@entry path / /index.html /debug-console.html /sw.js /manifest.webmanifest /registerSW.js
		header @entry Cache-Control "no-cache"
		@hashed path /assets/* /workbox-*.js
		header @hashed Cache-Control "public, max-age=31536000, immutable"

		file_server
	}
}

{$JBRAIN_SITE_ADDR} {
	# The owner debug console is LAN-only: its page must not be reachable from the
	# public internet, so 404 its entry here. The LAN site below (which also imports
	# app) still serves it. The shared hash-named /assets/* carry no secrets, and
	# the /api/debug/* surface stays reachable (an external assistant connects to it
	# with a token) — it is only the human-facing console PAGE that is LAN-gated.
	handle /debug-console* {
		respond 404
	}
	import app
}

# Optional LAN site: when JBRAIN_LAN_ADDR is set (e.g. https://jbrain.local) the
# proxy entrypoint writes a site block here that serves the same app over HTTPS
# from Caddy's internal CA. This makes the Secure session cookie work on the
# local network even when the Cloudflare tunnel / internet is down. Unset -> no
# file is written, so this glob matches nothing and only the public site runs.
# See docs/runbooks/LOCAL_ACCESS.md.
import /etc/caddy/lan/*.caddy

# Optional host-mode jcode web preview: when JBRAIN_JCODE_PREVIEW_BASE_HOST is set the
# entrypoint renders a wildcard site here that routes <slug>-preview.<host> to the api's
# /__jcode_preview/<slug> (docs/JCODE_PREVIEW_HOST_PLAN.md). Unset -> the glob matches
# nothing, so a stock deploy is unaffected.
import /etc/caddy/preview/*.caddy
