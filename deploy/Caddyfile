# flush_interval -1 disables response buffering so SSE log streams arrive
# line-by-line instead of in bursts.
{$JBRAIN_DOMAIN} {
	encode zstd gzip

	handle /api/* {
		reverse_proxy api:8000 {
			flush_interval -1
		}
	}

	handle {
		root * /srv/www
		try_files {path} /index.html

		# The PWA's update entrypoints must always revalidate, while Vite's
		# hash-named assets are immutable — this pair is what makes every
		# launch pick up a new deploy.
		@entry path / /index.html /sw.js /manifest.webmanifest /registerSW.js
		header @entry Cache-Control "no-cache"
		@hashed path /assets/* /workbox-*.js
		header @hashed Cache-Control "public, max-age=31536000, immutable"

		file_server
	}
}
