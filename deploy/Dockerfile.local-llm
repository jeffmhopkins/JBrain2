# OPT-IN local model gateway for AMD Strix Halo (gfx1151).
#
# Rather than build llama.cpp ourselves (a moving target against the gfx1151
# Vulkan/ROCm runtime — Mesa/glslc versions, kernel quirks), we base on the
# community-maintained, hardware-tested llama.cpp image from the
# amd-strix-halo-toolboxes project, which ships a working `llama-server` kept in
# sync with llama.cpp master, and layer on llama-swap (multi-model OpenAI
# gateway). The base is selectable: the default is the Vulkan/RADV build (only
# needs /dev/dri); a `rocm-*` tag enables the ROCm/rocWMMA path (faster on
# gfx1151, but also needs /dev/kfd + seccomp=unconfined — see docker-compose.yml).
#
# Host prerequisites for gfx1151 (the image can't supply these):
#   - kernel >= 6.18.4 (older has a gfx1151 stability bug)
#   - avoid linux-firmware-20251125 (breaks ROCm on Strix Halo)
#
# SUPPLY CHAIN: this is a community image. Pin LOCAL_LLM_BASE to a digest
# (kyuz0/amd-strix-halo-toolboxes@sha256:...) for a reproducible, trusted build
# once you've confirmed a tag works on your box.
#
# This image is built only when the operator enables local hosting; it is never
# part of the default stack.

# Declared in the global scope (before the first FROM) so it is visible to the
# runtime FROM below; an ARG declared after a FROM is scoped to that stage and
# the later FROM would resolve it to blank.
ARG LOCAL_LLM_BASE=docker.io/kyuz0/amd-strix-halo-toolboxes:vulkan-radv

# Build llama-swap (pure-Go) in a throwaway stage so we don't need a toolchain
# in the runtime image. PIN LLAMA_SWAP_VERSION to a tag (e.g. v167) for a
# reproducible build.
FROM golang:1.23-bookworm AS swap
ENV GOTOOLCHAIN=auto
ARG LLAMA_SWAP_VERSION=latest
RUN GOBIN=/out go install "github.com/mostlygeek/llama-swap@${LLAMA_SWAP_VERSION}"

FROM ${LOCAL_LLM_BASE}

# llama-swap is a static Go binary — drops in next to the image's llama-server
# (which is on PATH; the generated config invokes it by name).
COPY --from=swap /out/llama-swap /usr/local/bin/llama-swap

EXPOSE 8080
