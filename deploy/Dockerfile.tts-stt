# The `tts-stt` speech service: whisper.cpp speech-to-text AND warm piper text-to-speech
# in one always-on container (the box's speech I/O).
#
# STT half — whisper.cpp's server compiled onto the official llama-swap unified Vulkan image
# (which bundles llama-server + sd-server + llama-swap + ffmpeg, but NOT whisper.cpp). Built
# in the SAME base so the binary's glibc/libstdc++ match the runtime. A CPU build keeps it
# self-contained (ggml falls back to CPU; large-v3-turbo is quick on the Strix Halo CPU).
#
# TTS half — Python + piper-tts + the baked default voices. piper_server.py (bind-mounted
# at /tts, like the wall's serve.py) holds each voice's model resident and reuses it, so a
# read-aloud clip renders in ~0.1s instead of cold-loading the model every call.
#
# Both services are DEFAULT-ON now (dropped the opt-in `whisper` profile), so a stock deploy
# has read-aloud (piper) and, once its model is provisioned, transcription (whisper).

ARG WHISPER_BASE=ghcr.io/mostlygeek/llama-swap:vulkan

FROM ${WHISPER_BASE} AS build
RUN apt-get update \
 && apt-get install -y --no-install-recommends git build-essential cmake ca-certificates \
 && rm -rf /var/lib/apt/lists/*
# Pin a known-good whisper.cpp release (carries --inference-path + --convert, the
# OpenAI-audio-endpoint flags the gateway config relies on).
ARG WHISPER_CPP_VERSION=v1.7.4
RUN git clone --depth 1 --branch "${WHISPER_CPP_VERSION}" \
      https://github.com/ggml-org/whisper.cpp /src
WORKDIR /src
# Static link (BUILD_SHARED_LIBS=OFF) so whisper-server carries its own ggml and
# can't collide with the base image's bundled libggml*.so (a different version).
RUN cmake -B build -DCMAKE_BUILD_TYPE=Release -DBUILD_SHARED_LIBS=OFF \
      -DWHISPER_BUILD_TESTS=OFF -DWHISPER_BUILD_EXAMPLES=ON \
 && cmake --build build --target whisper-server -j"$(nproc)"

FROM ${WHISPER_BASE}
# STT: whisper-server onto PATH so the generated llama-swap config can invoke it by name.
COPY --from=build /src/build/bin/whisper-server /usr/local/bin/whisper-server

# TTS: Python runtime + piper (onnxruntime's OpenMP dep is libgomp1; espeak-ng is Kokoro's
# phonemizer backend — kokoro-onnx bundles it via espeakng-loader, kept here as a belt-and-
# suspenders). --break-system-packages installs into the container's system python (PEP 668) —
# fine for a single-purpose image. piper-tts is the ALWAYS-ON half read-aloud depends on, so it
# stays fatal; onnxruntime rides in as its dependency.
RUN apt-get update \
 && apt-get install -y --no-install-recommends python3 python3-pip libgomp1 espeak-ng \
 && rm -rf /var/lib/apt/lists/* \
 && pip install --no-cache-dir --break-system-packages piper-tts

# Kokoro-82M is an OPTIONAL second TTS engine — its pip install must NEVER fail the image build
# (a Kokoro-only hiccup would otherwise abort the whole stack's `jbrain update`, since one build
# recreates every service). On failure the image still builds and read-aloud runs piper-only; the
# weight fetch below is skipped unless this import succeeds, so /opt/kokoro stays empty and
# piper_server lists no Kokoro voices (never a dead, listed voice). Pinned to 0.4.7 — the newest
# release whose Requires-Python (>=3.9, no upper bound) installs on this base image's Python 3.14;
# 0.4.8+/0.5.x cap at <3.14 and pip refuses them here. Same Kokoro()/.create() API and same v1.0
# model files as 0.5.x, so the render code is unchanged. Bump when the base's Python moves.
RUN pip install --no-cache-dir --break-system-packages kokoro-onnx==0.4.7 \
 || echo "[kokoro] pip install failed — read-aloud will run piper-only until the next build"

# misaki — Kokoro's recommended G2P: better English pronunciation than espeak (POS-based
# homographs, num2words), with an espeak fallback for OOV. INDEPENDENT of kokoro-onnx above and
# NON-FATAL: if misaki or its small spaCy model (en_core_web_sm; piper_server uses trf=False to
# stay on it and bound RAM) fails to install, the Kokoro path phonemizes with its built-in espeak
# instead — never a broken read-aloud or a blocked update. Keep the "misaki" token here in step
# with piper_server.py's _load_g2p (the test guards it).
RUN (pip install --no-cache-dir --break-system-packages "misaki[en]" \
      && python3 -m spacy download en_core_web_sm) \
 || echo "[kokoro] misaki G2P unavailable — Kokoro will phonemize with espeak until the next build"

# Baked default voices: Joe reads prompts, Amy reads answers, plus the multi-speaker
# libritts_r model whose curated speaker 3922 is a second female agent voice. Fetched with
# stdlib urllib (follows HF's CDN redirect) into /opt/piper-voices (outside the /tts mount).
# This tuple is the baked source of truth and must stay in step with install-tts.sh's MODELS.
RUN python3 -c "import urllib.request as u; from pathlib import Path; \
d=Path('/opt/piper-voices'); d.mkdir(parents=True, exist_ok=True); \
B='https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US'; \
[ (print('[voices]', v, e, flush=True), u.urlretrieve(f'{B}/{v}/medium/en_US-{v}-medium{e}', d/f'en_US-{v}-medium{e}')) for v in ('joe','amy','libritts_r') for e in ('.onnx','.onnx.json') ]"

# Kokoro-82M voices (Apache-2.0): ONE shared onnx model + a voice-styles bin that together serve
# many voices, baked into /opt/kokoro — its OWN dir, so the piper voice glob never scans it. These
# are the canonical kokoro-onnx release artifacts. Fetched with retry (they total ~340 MB from
# GitHub). Like the pip step, this is NON-FATAL — a transient blip or blocked egress must not abort
# an otherwise-fine `jbrain update`. The `|| echo` swallows the failure; a giving-up SystemExit
# leaves /opt/kokoro empty-or-partial, and piper_server's weights-both-present gate then lists no
# Kokoro voices (piper-only) rather than a broken one. Skipped entirely unless the package imported,
# so weights are never present without a runtime to use them. The filenames must stay in step with
# piper_server.py's KOKORO_MODEL/KOKORO_VOICES_FILE (the test guards this).
RUN python3 - <<'PY' \
 || echo "[kokoro] weight fetch unavailable — read-aloud will run piper-only until the next build"
import importlib.util
import time
import urllib.request
from pathlib import Path

if importlib.util.find_spec("kokoro_onnx") is None:
    raise SystemExit("[kokoro] package not installed; skipping weight fetch")

d = Path("/opt/kokoro")
d.mkdir(parents=True, exist_ok=True)
base = "https://github.com/thewh1teagle/kokoro-onnx/releases/download/model-files-v1.0"
for name in ("kokoro-v1.0.onnx", "voices-v1.0.bin"):
    dest = d / name
    for attempt in range(4):
        try:
            print(f"[kokoro] fetching {name} (attempt {attempt + 1})", flush=True)
            urllib.request.urlretrieve(f"{base}/{name}", dest)
            break
        except Exception as exc:  # noqa: BLE001
            print(f"[kokoro] {name} failed: {exc}", flush=True)
            time.sleep(2 * (attempt + 1))
    else:
        raise SystemExit(f"[kokoro] giving up on {name}")
PY

# No app COPY: piper_server.py + entrypoint.sh are bind-mounted at /tts and launched via the
# compose entrypoint (which starts the piper server, then execs llama-swap). Only the baked
# voices + the whisper/piper runtimes live in the image.
