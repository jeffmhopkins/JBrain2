#!/usr/bin/env bash
# Host-side operator CLI. Shares code paths with the supervisor's command set
# so a wedged stack is always recoverable over SSH.
set -euo pipefail

cd /opt/jbrain2

# The opt-in GPU gateway lives behind the `local-llm` compose profile. Activate
# it for routine commands ONLY when the operator enabled local hosting, so a
# stock stack never builds/starts it. (We deliberately do NOT persist
# COMPOSE_PROFILES in .env — that would drag the gateway into every command and
# silently drop the `tools` profile.)
PROFILE=()
if [ -f .env ] && grep -q '^LOCAL_LLM_ENABLED=true' .env; then
  PROFILE+=(--profile local-llm)
fi
# The opt-in Cloudflare Tunnel connector lives behind the `tunnel` profile. Keep
# it in every routine command when enabled so the connector is started, stopped,
# and restarted alongside the rest of the stack.
if [ -f .env ] && grep -q '^TUNNEL_ENABLED=true' .env; then
  PROFILE+=(--profile tunnel)
fi

usage() {
  cat <<EOF
Usage: jbrain <command>

  status           container states
  restart [svc]    restart one service or the whole stack
  logs [svc]       follow logs (default: all services)
  reset-owner-key  revoke the owner key and print a new one
  update           pull latest source, rebuild, migrate, restart
  enable-lan       set up LAN access (mDNS + jbrain.local alias) on this host
  enable-local-models [ids...]  provision + enable self-hosted local models
  strix-halo-host-setup [args]  one-time AMD Strix Halo host prep (kernel/udev)
  backup           run a backup now
  restore [stamp]  restore a backup (no stamp: list available)
  down | up        stop / start the stack
EOF
}

case "${1:-}" in
  status)
    docker compose "${PROFILE[@]}" ps
    ;;
  restart)
    docker compose "${PROFILE[@]}" restart ${2:-}
    ;;
  logs)
    docker compose "${PROFILE[@]}" logs -f --tail 200 ${2:-}
    ;;
  reset-owner-key)
    docker compose run --rm api python -m jbrain.cli reset-owner-key
    ;;
  update)
    ./backup.sh || echo "backup skipped (stack not running yet?)"
    git -C src pull --ff-only
    # Refresh helpers from the updated tree; mv keeps this running script
    # reading its old inode safely.
    for f in docker-compose.yml backup.sh restore.sh jbrain; do
      cp "src/deploy/$f" "$f.new" && mv "$f.new" "$f"
    done
    cp src/deploy/db-init/01-app-role.sh db-init/
    chmod +x jbrain backup.sh restore.sh db-init/01-app-role.sh
    # Refresh the SearXNG settings host file (writable bind mount; enables the
    # JSON format web_search needs) and backfill its secret for stacks older
    # than the web-search service — without these jerv reports web search as
    # unavailable. See update-inner.sh for the full rationale.
    mkdir -p searxng
    rm -rf searxng/settings.yml
    cp src/deploy/searxng/settings.yml searxng/settings.yml
    if ! grep -q '^SEARXNG_SECRET=' .env; then
      printf 'SEARXNG_SECRET=%s\n' "$(openssl rand -hex 32)" >> .env
    fi
    # Turn LAN access on for installs that predate it, then (re)provision the
    # host mDNS + alias from the freshly pulled source. Best-effort: a setup
    # failure must not abort an update.
    if ! grep -q '^JBRAIN_LAN_ADDR=' .env; then
      printf 'JBRAIN_LAN_ADDR=%s\n' "https://jbrain.local" >> .env
    fi
    if grep -q '^JBRAIN_LAN_ADDR=https' .env; then
      JBRAIN_INSTALL_DIR=/opt/jbrain2 bash /opt/jbrain2/src/deploy/lan-setup.sh \
        || echo "LAN setup skipped (run 'jbrain enable-lan' to retry)"
    fi
    docker compose "${PROFILE[@]}" build
    docker compose run --rm migrate
    docker compose "${PROFILE[@]}" up -d
    # Reclaim layers orphaned by the rebuild; shared (cached) layers survive,
    # so disk use stays bounded without losing build speed.
    docker image prune -f
    docker builder prune -f --keep-storage 10GB >/dev/null 2>&1 || true
    ;;
  enable-lan)
    # Host half of LAN access: mDNS responder + the CNAME alias that resolves
    # JBRAIN_LAN_ADDR (jbrain.local). The Caddy HTTPS site is already on by
    # default in compose; this makes the name resolvable on the network.
    JBRAIN_INSTALL_DIR=/opt/jbrain2 bash /opt/jbrain2/src/deploy/lan-setup.sh
    ;;
  enable-local-models)
    shift
    # Opt-in, heavy (downloads weights, starts a GPU service). The provisioning
    # logic lives with the source so it tracks the catalog. Absolute path so it
    # works regardless of cwd.
    JBRAIN_INSTALL_DIR=/opt/jbrain2 bash /opt/jbrain2/src/scripts/local-llm-setup.sh "$@"
    ;;
  strix-halo-host-setup)
    shift
    # One-time host prep (kernel params, GPU perms, perf profile). Edits GRUB +
    # udev and needs a reboot — deliberately separate from the stack.
    bash /opt/jbrain2/src/scripts/strix-halo-host-setup.sh "$@"
    ;;
  backup)
    ./backup.sh
    ;;
  restore)
    ./restore.sh ${2:-}
    ;;
  down)
    docker compose "${PROFILE[@]}" down
    ;;
  up)
    docker compose "${PROFILE[@]}" up -d
    ;;
  *)
    usage
    exit 1
    ;;
esac
