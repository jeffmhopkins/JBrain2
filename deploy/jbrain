#!/usr/bin/env bash
# Host-side operator CLI. Shares code paths with the supervisor's command set
# so a wedged stack is always recoverable over SSH.
set -euo pipefail

cd /opt/jbrain2

# The opt-in GPU gateway lives behind the `local-llm` compose profile. Activate
# it for routine commands ONLY when the operator enabled local hosting, so a
# stock stack never builds/starts it. (We deliberately do NOT persist
# COMPOSE_PROFILES in .env — that would drag the gateway into every command and
# silently drop the `tools` profile.)
PROFILE=()
if [ -f .env ] && grep -q '^LOCAL_LLM_ENABLED=true' .env; then
  PROFILE+=(--profile local-llm)
fi
# The opt-in on-box speech-to-text gateway lives behind the `whisper` profile.
# Keep it in routine commands when enabled so it is built, started, and restarted
# alongside the rest of the stack (and rebuilt by `update`).
if [ -f .env ] && grep -q '^WHISPER_ENABLED=true' .env; then
  PROFILE+=(--profile whisper)
fi
# The opt-in Cloudflare Tunnel connector lives behind the `tunnel` profile. Keep
# it in every routine command when enabled so the connector is started, stopped,
# and restarted alongside the rest of the stack.
if [ -f .env ] && grep -q '^TUNNEL_ENABLED=true' .env; then
  PROFILE+=(--profile tunnel)
fi
# The opt-in code-mode sandbox lives behind the `jcode` profile. Keep it in routine
# commands when enabled so it is built, started, restarted, and rebuilt by `update`
# alongside the rest of the stack — host parity with the PWA update path.
if [ -f .env ] && grep -q '^JCODE_ENABLED=true' .env; then
  PROFILE+=(--profile jcode)
fi

usage() {
  cat <<EOF
Usage: jbrain <command>

  status           container states
  restart [svc]    restart one service or the whole stack
  logs [svc]       follow logs (default: all services)
  reset-owner-key  revoke the owner key and print a new one
  update           pull latest source, rebuild, migrate, restart
  enable-lan       set up LAN access (mDNS + jbrain.local alias) on this host
  enable-local-models [ids...]  provision + enable self-hosted local models
  enable-whisper [model]        provision + enable on-box audio transcription
  strix-halo-host-setup [args]  one-time AMD Strix Halo host prep (kernel/udev)
  backup           run a backup now
  restore [stamp]  restore a backup (no stamp: list available)
  down | up        stop / start the stack
EOF
}

case "${1:-}" in
  status)
    docker compose "${PROFILE[@]}" ps
    ;;
  restart)
    docker compose "${PROFILE[@]}" restart ${2:-}
    ;;
  logs)
    docker compose "${PROFILE[@]}" logs -f --tail 200 ${2:-}
    ;;
  reset-owner-key)
    docker compose run --rm api python -m jbrain.cli reset-owner-key
    ;;
  update)
    ./backup.sh || echo "backup skipped (stack not running yet?)"
    # Mirror the remote exactly rather than `pull --ff-only`: a deploy box should
    # never diverge, but if it has (a stray commit/edit), ff-only refuses and — under
    # `set -e` — aborts the whole update, leaving the stack pinned to stale source
    # that every rebuild keeps baking. fetch + hard reset to the tracked upstream
    # self-heals, discarding local src changes by design (src is a pristine mirror).
    git -C src fetch origin
    git -C src reset --hard "@{u}"
    # Refresh helpers from the updated tree; mv keeps this running script
    # reading its old inode safely.
    for f in docker-compose.yml backup.sh restore.sh jbrain; do
      cp "src/deploy/$f" "$f.new" && mv "$f.new" "$f"
    done
    cp src/deploy/db-init/01-app-role.sh db-init/
    chmod +x jbrain backup.sh restore.sh db-init/01-app-role.sh
    # Refresh the SearXNG settings host file (writable bind mount; enables the
    # JSON format web_search needs) and backfill its secret for stacks older
    # than the web-search service — without these jerv reports web search as
    # unavailable. See update-inner.sh for the full rationale.
    mkdir -p searxng
    rm -rf searxng/settings.yml
    cp src/deploy/searxng/settings.yml searxng/settings.yml
    if ! grep -q '^SEARXNG_SECRET=' .env; then
      printf 'SEARXNG_SECRET=%s\n' "$(openssl rand -hex 32)" >> .env
    fi
    # Code mode (jcode): self-heal its .env keys when enabled so the host update
    # keeps it turnkey too — mint the api<->jcode bearer + fail-closed defaults
    # (compose maps these to the api as JBRAIN_JCODE_* and to the sandbox as
    # JCODE_*). The jcode profile is already active above, so build/up include it.
    if grep -q '^JCODE_ENABLED=true' .env; then
      if ! grep -q '^JCODE_TOKEN=..*' .env; then
        printf 'JCODE_TOKEN=%s\n' "$(openssl rand -hex 32)" >> .env
      fi
      grep -q '^JCODE_URL=' .env || printf 'JCODE_URL=%s\n' 'http://jcode:9100' >> .env
      grep -q '^JCODE_MODEL=' .env || printf 'JCODE_MODEL=%s\n' 'qwen3-coder-next' >> .env
      grep -q '^JCODE_MODEL_URL=' .env || printf 'JCODE_MODEL_URL=%s\n' 'http://local-llm:8080' >> .env
    fi
    # Turn LAN access on for installs that predate it, then (re)provision the
    # host mDNS + alias from the freshly pulled source. Best-effort: a setup
    # failure must not abort an update.
    if ! grep -q '^JBRAIN_LAN_ADDR=' .env; then
      printf 'JBRAIN_LAN_ADDR=%s\n' "https://jbrain.local" >> .env
    fi
    if grep -q '^JBRAIN_LAN_ADDR=https' .env; then
      JBRAIN_INSTALL_DIR=/opt/jbrain2 bash /opt/jbrain2/src/deploy/lan-setup.sh \
        || echo "LAN setup skipped (run 'jbrain enable-lan' to retry)"
    fi
    docker compose "${PROFILE[@]}" build
    docker compose run --rm migrate
    docker compose "${PROFILE[@]}" up -d
    # When on-box image generation is enabled, re-sync its models so an update that adds
    # newly-recommended models (or new weight files for existing ones) downloads them without a
    # separate manual step. We provision the UNION of the operator's current selection and the
    # recommended set, so nothing they chose is dropped and anything newly recommended is pulled
    # (hf skips files already present, so an unchanged set is a cheap no-op). The api image is
    # rebuilt above, so the catalog read sees the new code. Best-effort: a provisioning failure
    # must never abort the update — the operator can re-run `sudo bash scripts/comfyui-setup.sh`.
    if grep -q '^COMFYUI_ENABLED=true' .env; then
      current_models="$(python3 -c "import json,re; t=open('.env').read(); m=re.search(r'^COMFYUI_MODELS=(.*)\$',t,re.M); print(' '.join(json.loads(m.group(1))) if m else '')" 2>/dev/null || true)"
      reco_models="$(docker compose run --rm --no-deps -T api python -c "from jbrain.image_gen import catalog; print(' '.join(catalog.recommended_ids()))" 2>/dev/null || true)"
      sync_ids="$(printf '%s\n%s\n' "$current_models" "$reco_models" | tr ' ' '\n' | grep -v '^[[:space:]]*$' | sort -u | tr '\n' ' ')"
      if [ -n "${sync_ids// /}" ]; then
        echo "[update] syncing on-box image models: $sync_ids"
        JBRAIN_INSTALL_DIR=/opt/jbrain2 bash /opt/jbrain2/src/scripts/comfyui-setup.sh $sync_ids \
          || echo "[update] image-model sync skipped (retry: sudo bash scripts/comfyui-setup.sh)"
      fi
    fi
    # Provision local LLM models the operator queued from the PWA + keep the
    # current/recommended set present — host parity with the PWA update path
    # (deploy/update-inner.sh). The shared sync is POSIX sh; best-effort so a
    # provisioning hiccup never aborts the update.
    bash /opt/jbrain2/src/deploy/local-models-sync.sh \
      || echo "[update] local-model sync skipped (retry on next update)"
    # Reclaim layers orphaned by the rebuild; shared (cached) layers survive,
    # so disk use stays bounded without losing build speed.
    docker image prune -f
    docker builder prune -f --keep-storage 10GB >/dev/null 2>&1 || true
    ;;
  enable-lan)
    # Host half of LAN access: mDNS responder + the CNAME alias that resolves
    # JBRAIN_LAN_ADDR (jbrain.local). The Caddy HTTPS site is already on by
    # default in compose; this makes the name resolvable on the network.
    JBRAIN_INSTALL_DIR=/opt/jbrain2 bash /opt/jbrain2/src/deploy/lan-setup.sh
    ;;
  enable-local-models)
    shift
    # Opt-in, heavy (downloads weights, starts a GPU service). The provisioning
    # logic lives with the source so it tracks the catalog. Absolute path so it
    # works regardless of cwd.
    JBRAIN_INSTALL_DIR=/opt/jbrain2 bash /opt/jbrain2/src/scripts/local-llm-setup.sh "$@"
    ;;
  enable-whisper)
    shift
    # Opt-in, heavy (downloads a GGML model, starts a GPU service). Provisioning
    # lives with the source. Absolute path so it works regardless of cwd.
    JBRAIN_INSTALL_DIR=/opt/jbrain2 bash /opt/jbrain2/src/scripts/whisper-setup.sh "$@"
    ;;
  strix-halo-host-setup)
    shift
    # One-time host prep (kernel params, GPU perms, perf profile). Edits GRUB +
    # udev and needs a reboot — deliberately separate from the stack.
    bash /opt/jbrain2/src/scripts/strix-halo-host-setup.sh "$@"
    ;;
  backup)
    ./backup.sh
    ;;
  restore)
    ./restore.sh ${2:-}
    ;;
  down)
    docker compose "${PROFILE[@]}" down
    ;;
  up)
    docker compose "${PROFILE[@]}" up -d
    ;;
  *)
    usage
    exit 1
    ;;
esac
